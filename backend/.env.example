# Lumiqe Backend — Environment Variables
# Copy this file to .env and adjust values as needed.

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lumiqe_dev

# ─── JWT Authentication (REQUIRED — app won't start without this) ─
# Must be at least 32 characters. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_random_string_at_least_32_chars

# ─── Redis (Rate Limiting) ───────────────────────────────────
# Leave unset to disable rate limiting (dev mode)
# REDIS_URL=redis://localhost:6379

# ─── Stripe Payments ─────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret from Stripe Dashboard or `stripe listen`
# STRIPE_WEBHOOK_SECRET=whsec_...
# Pre-created Stripe Price IDs (recommended for production)
# STRIPE_MONTHLY_PRICE_ID=price_...
# STRIPE_ANNUAL_PRICE_ID=price_...
FRONTEND_URL=http://localhost:3000

# ─── Firecrawl (Shopping Agent) ──────────────────────────────
# Get from https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-...

# ─── Groq (AI Stylist / Styling Tips) ────────────────────────
# Get from https://console.groq.com
# GROQ_API_KEY=gsk_...

# ─── BiSeNet Model Weights ───────────────────────────────────
# Auto-downloaded on startup if set. Leave unset for local dev with pre-downloaded weights.
# BISENET_WEIGHTS_URL=https://...

# ─── Affiliate Links ───────────────────────────────────────
# Amazon Associates tag (e.g., lumiqe-21)
# AFFILIATE_AMAZON_TAG=lumiqe-21
# CueLinks publisher ID (for Myntra, Ajio)
# AFFILIATE_CUELINKS_PID=...
# Admitad affiliate UID (for Bewakoof, Snitch)
# AFFILIATE_ADMITAD_UID=...

# ─── Email (Resend) ─────────────────────────────────────────
# Get from https://resend.com — free tier: 3,000 emails/month
# RESEND_API_KEY=re_...
# EMAIL_FROM=Lumiqe <hello@lumiqe.in>

# ─── Observability ───────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ─── Debug ───────────────────────────────────────────────────
DEBUG=true
