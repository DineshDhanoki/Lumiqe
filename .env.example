# ─── Lumiqe — Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SECURE_PASSWORD@localhost:5432/lumiqe_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
POSTGRES_DB=lumiqe_dev

# ─── JWT Authentication (REQUIRED) ──────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── NextAuth (REQUIRED for frontend) ───────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Redis (Rate Limiting) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── External APIs ──────────────────────────────────────────
FIRECRAWL_API_KEY=
GROQ_API_KEY=

# ─── Debug ───────────────────────────────────────────────────
DEBUG=false
